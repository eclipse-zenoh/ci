{
  "name": "@eclipse-zenoh/ci",
  "description": "GitHub JavaScript Actions for Eclipse Zenoh CI/CD",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "format:write": "prettier --write **/*.ts",
    "format:check": "prettier --check **/*.ts",
    "lint": "npx eslint . -c eslint.config.mjs",
    "build": "./build.cjs",
    "build:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --detectOpenHandles",
    "all": "npm run format:write && npm run lint && npm run test && npm run build",
    "clean": "rm dist/*"
  },
  "license": "(Apache-2.0 OR EPL-2.0)",
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/cache": "^6.0.1",
    "@actions/core": "^3.0.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/node-fetch": "^3.0.2",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.4.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "prettier-eslint": "^16.4.2",
    "ts-jest": "^29.4.10",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}